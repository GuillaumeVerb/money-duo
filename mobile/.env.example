EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# URL publique de l’app web (invitations + redirections e-mail Auth), sans slash final
EXPO_PUBLIC_WEB_APP_URL=https://your-app.vercel.app
# Optionnel — affiche « Contacter le support » dans Réglages (mailto)
EXPO_PUBLIC_SUPPORT_EMAIL=support@example.com
# Optionnel — ouvre un navigateur au lieu des écrans in-app
# EXPO_PUBLIC_PRIVACY_POLICY_URL=https://example.com/privacy
# EXPO_PUBLIC_TERMS_URL=https://example.com/terms
