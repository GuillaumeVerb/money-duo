{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "export:web": "expo export --platform web",
    "eas:init": "npx eas-cli@latest init",
    "eas:build:ios": "npx eas-cli@latest build --platform ios --profile production",
    "eas:build:android": "npx eas-cli@latest build --platform android --profile production",
    "eas:build:all": "npx eas-cli@latest build --platform all --profile production",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.cjs --forceExit",
    "test:attachment": "jest --config jest.config.cjs --forceExit --testPathPatterns=attachmentUrl"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/bottom-tabs": "^7.15.6",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/native-stack": "^7.14.6",
    "@supabase/supabase-js": "^2.99.3",
    "babel-preset-expo": "~55.0.8",
    "expo": "~55.0.8",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-file-system": "~55.0.11",
    "expo-linking": "~55.0.8",
    "expo-notifications": "~55.0.13",
    "expo-sharing": "~55.0.14",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "~19.2.2",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "private": true
}
